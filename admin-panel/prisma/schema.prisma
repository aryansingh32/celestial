generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeviceScan {
  id                      String   @id @default(cuid())
  createdAt               DateTime @default(now())
  deviceId                String?

  // Connection details
  publicIp                String?
  userAgent               String?
  referer                 String?
  language                String?

  // Client details (from JS)
  screenResolution        String?
  timezone                String?
  installedFonts          String?
  canvasFingerprint       String?
  webglFingerprint        String?
  audioFingerprint        String?
  hardwareConcurrency     Int?
  deviceMemory            Int?
  touchSupport            Boolean?
  browserPlugins          String?
  batteryLevel            Float?
  connectionType          String?

  // User-provided details
  userName                String?
  birthDate               String?
  birthState              String?
  birthCity               String?
  birthTime               String?

  // Location (user-opted-in GPS)
  latitude                Float?
  longitude               Float?
  neighborhoodReading     Json?

  // Payload
  image                   String? // Base64 data string

  // Result
  reading                 Json?
}

model DeviceCommand {
  id        String   @id @default(cuid())
  deviceId  String
  command   String   // "REQUEST_LOCATION", "REQUEST_NOTIFICATION", "SHOW_NOTIFICATION"
  payload   String?  // Notification text
  status    String   @default("pending") // pending, completed
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  password  String   @unique
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())

  sharedDevices DeviceShare[]
}

model DeviceShare {
  id          String   @id @default(cuid())
  adminUserId String
  deviceId    String
  createdAt   DateTime @default(now())

  user AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  
  @@unique([adminUserId, deviceId])
}

model TelegramUser {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  createdAt DateTime @default(now())
}
